{
  "name": "@instana/branch-updater",
  "version": "1.0.0",
  "description": "A GitHub App which ensures that your main development branch is up to date.",
  "author": "Ben Ripkens <bripkens@gmail.com>",
  "license": "MIT",
  "repository": "https://github.com/instana/branch-updater.git",
  "homepage": "https://github.com/instana/branch-updater",
  "bugs": "https://github.com/instana/branch-updater/issues",
  "keywords": [
    "probot",
    "github",
    "probot-app",
    "instana"
  ],
  "scripts": {
    "start": "probot run ./src/index.js",
    "lint": "standard --fix",
    "test": "jest && standard",
    "test:watch": "jest --watch --notify --notifyMode=change --coverage"
  },
  "dependencies": {
    "@probot/adapter-aws-lambda-serverless": "^4.0.3",
    "probot": "^13.4.5"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nock": "^14.0.5",
    "nodemon": "^3.1.10",
    "serverless": "^4.17.0",
    "serverless-offline": "^14.4.0",
    "serverless-offline-ssm": "^6.2.0",
    "smee-client": "^4.2.1",
    "standard": "^17.1.2"
  },
  "engines": {
    "node": ">= 10.13.0"
  },
  "standard": {
    "env": [
      "jest"
    ]
  },
  "nodemonConfig": {
    "exec": "npm start",
    "watch": [
      ".env",
      "."
    ]
  },
  "jest": {
    "testEnvironment": "node"
  }
}
